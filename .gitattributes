# Normalize line endings: Git stores LF, checks out native on Windows.
* text=auto

# Always LF for these (shell scripts, Go, web assets, configs)
*.sh   text eol=lf
*.go   text eol=lf
*.js   text eol=lf
*.css  text eol=lf
*.html text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.md   text eol=lf
